{
  "name": "polyglot-lang",
  "displayName": "Polyglot language server",
  "description": "Language support for Polyglot (.pg): syntax highlighting + a language server (diagnostics, go-to-definition, hover, document symbols, formatting) + watch mode (rebuild emitted outputs on save).",
  "version": "0.4.1",
  "publisher": "mintplayer",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#30BF87",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MintPlayer/MintPlayer.Polyglot"
  },
  "engines": { "vscode": "^1.82.0" },
  "categories": ["Programming Languages", "Formatters", "Linters"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:polyglot"],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "commands": [
      {
        "command": "polyglot.showOutput",
        "title": "Show Generated Output",
        "category": "Polyglot",
        "icon": "$(file-code)"
      },
      {
        "command": "polyglot.startWatch",
        "title": "Start Watch (emit output files on change)",
        "category": "Polyglot",
        "icon": "$(eye)"
      },
      {
        "command": "polyglot.stopWatch",
        "title": "Stop Watch",
        "category": "Polyglot",
        "icon": "$(eye-closed)"
      }
    ],
    "taskDefinitions": [
      {
        "type": "polyglot",
        "required": ["task", "file"],
        "properties": {
          "task": {
            "type": "string",
            "enum": ["watch"],
            "description": "The polyglot task kind (only 'watch' exists)."
          },
          "file": {
            "type": "string",
            "description": "The entry .pg file to watch (workspace-relative or absolute)."
          },
          "target": {
            "type": "string",
            "description": "A single target to emit; omit to emit the pgconfig 'targets' set (or the cs+ts default)."
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "polyglot-watch",
        "label": "Polyglot watch problems",
        "owner": "polyglot",
        "source": "polyglot",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.+?)\\((\\d+),(\\d+)\\):\\s+(error|warning|info):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[\\d{2}:\\d{2}:\\d{2}\\] polyglot watch: (?:re)?building ",
          "endsPattern": "^\\[\\d{2}:\\d{2}:\\d{2}\\] polyglot watch: \\d+ error\\(s\\) - watching for changes$"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "polyglot.showOutput",
          "when": "resourceLangId == polyglot",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "polyglotOutputs",
          "name": "Polyglot Outputs",
          "visibility": "collapsed",
          "when": "polyglot.hasOutputs"
        }
      ]
    },
    "languages": [
      {
        "id": "polyglot",
        "aliases": ["Polyglot", "polyglot"],
        "extensions": [".pg"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "polyglot",
        "scopeName": "source.polyglot",
        "path": "./syntaxes/polyglot.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Polyglot",
      "properties": {
        "polyglot.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the polyglot CLI executable (which hosts the language server via `polyglot lsp`). Leave empty to auto-discover: the bundled CLI shipped in the extension, then 'polyglot' on PATH, then a source-checkout build (x64/Release|Debug/MintPlayer.Polyglot.Cli.exe). Set this only to override — a bare name is looked up on PATH, a relative path is resolved against the workspace root, an absolute path is used as-is."
        },
        "polyglot.lib": {
          "type": "string",
          "default": "io,math",
          "description": "Comma-separated `lib` prelude sent to the server so ambient names (print, Math) resolve. Mirrors the CLI's --lib. Until per-project config (pgconfig.json) lands, this is the assumed prelude."
        },
        "polyglot.trace.server": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Trace the JSON-RPC traffic between VS Code and `polyglot lsp` (for debugging the server)."
        }
      }
    }
  }
}
