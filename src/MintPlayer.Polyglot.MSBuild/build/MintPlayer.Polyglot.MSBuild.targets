<Project>

  <!-- Auto-imported near the BOTTOM of the consuming project. Transpiles each @(PolyglotFile) to a .cs
       in obj/ before CoreCompile (so generated types exist for IntelliSense too — design-time builds are
       NOT skipped, Grpc.Tools' hard-won lesson), incrementally via Inputs/Outputs (the tool path is an
       input, so a CLI upgrade forces regen). A companion always-run target re-adds the generated files
       when the transpile is skipped, and registers them as FileWrites so `dotnet clean` removes them. -->

  <PropertyGroup>
    <PolyglotOutDir>$(IntermediateOutputPath)polyglot\</PolyglotOutDir>
    <!-- Host RID: the SDK's portable RID (e.g. win-x64, linux-x64, osx-arm64), overridable. Resolved
         here (not the .props) because the SDK defines it after NuGet's top-of-project props import. -->
    <PolyglotHostRid Condition="'$(PolyglotHostRid)' == ''">$(NETCoreSdkPortableRuntimeIdentifier)</PolyglotHostRid>
    <_PolyglotToolName Condition="$([MSBuild]::IsOSPlatform('Windows'))">polyglot.exe</_PolyglotToolName>
    <_PolyglotToolName Condition="'$(_PolyglotToolName)' == ''">polyglot</_PolyglotToolName>
    <PolyglotTool Condition="'$(PolyglotTool)' == ''">$(MSBuildThisFileDirectory)..\tools\$(PolyglotHostRid)\$(_PolyglotToolName)</PolyglotTool>
  </PropertyGroup>

  <!-- dotnet watch monitors only Compile/EmbeddedResource by default; declaring the .pg sources as Watch
       items makes `dotnet watch build|run` on the consuming project re-run PolyglotTranspile on every .pg
       edit — the free Visual Studio/.NET watch path (PRD 4.13). Opt out per file with Watch="false"
       metadata on the PolyglotFile item (it flows through the transform), or entirely with the
       PolyglotWatch=false property. -->
  <ItemGroup Condition="'$(PolyglotWatch)' != 'false'">
    <Watch Include="@(PolyglotFile)" />
  </ItemGroup>

  <!-- Fail LOUDLY when no packed binary matches the host — a silent skip would cascade into misleading
       "type not found" errors far from the cause. -->
  <Target Name="_PolyglotVerifyTool" Condition="'@(PolyglotFile)' != ''">
    <Error Condition="!Exists('$(PolyglotTool)')"
           Text="MintPlayer.Polyglot.MSBuild: no polyglot binary for host RID '$(PolyglotHostRid)' (looked at '$(PolyglotTool)'). Set the PolyglotTool property to a polyglot CLI for this platform." />
    <!-- NuGet extraction drops the exec bit on unix. -->
    <Exec Condition="!$([MSBuild]::IsOSPlatform('Windows'))" Command="chmod +x &quot;$(PolyglotTool)&quot;" />
  </Target>

  <!-- §4.5 module linking: transpile the WHOLE .pg set in ONE CLI invocation (not batched per file). The CLI
       links cross-module imports into references (each type/function defined once) and emits one flat .cs per
       .pg module — so compiling them all into one assembly no longer hits CS0101. A per-file invocation would
       double-emit shared library modules and clash on the C# `partial` wrapper. Output is flat (basename.cs),
       so .pg filenames must be unique across the project (v1 — see PRD §3.B). -->
  <Target Name="PolyglotTranspile"
          BeforeTargets="CoreCompile"
          DependsOnTargets="_PolyglotVerifyTool"
          Condition="'@(PolyglotFile)' != ''"
          Inputs="@(PolyglotFile);$(PolyglotTool)"
          Outputs="@(PolyglotFile->'$(PolyglotOutDir)%(Filename).cs')">
    <PropertyGroup>
      <_PolyglotLibArg></_PolyglotLibArg>
      <_PolyglotLibArg Condition="'$(PolyglotLib)' != ''"> --lib &quot;$(PolyglotLib)&quot;</_PolyglotLibArg>
      <!-- PolyglotAccess=public emits `public` on the generated C# types (usable across assemblies with no
           hand-written facade); unset keeps C#'s modifier-less default (internal). -->
      <_PolyglotAccessArg></_PolyglotAccessArg>
      <_PolyglotAccessArg Condition="'$(PolyglotAccess)' != ''"> --access &quot;$(PolyglotAccess)&quot;</_PolyglotAccessArg>
    </PropertyGroup>
    <MakeDir Directories="$(PolyglotOutDir)" />
    <Exec Command="&quot;$(PolyglotTool)&quot; build @(PolyglotFile->'&quot;%(FullPath)&quot;', ' ') --target csharp --out &quot;$(PolyglotOutDir).&quot; --root &quot;$(PolyglotRoot)&quot;$(_PolyglotLibArg)$(_PolyglotAccessArg)" />
  </Target>

  <!-- Always runs (no Inputs/Outputs): when PolyglotTranspile was skipped as up-to-date, the compiler
       still needs the previously generated files in @(Compile). One flat .cs per .pg module. -->
  <Target Name="_PolyglotAddGenerated"
          BeforeTargets="CoreCompile"
          AfterTargets="PolyglotTranspile"
          Condition="'@(PolyglotFile)' != ''">
    <ItemGroup>
      <Compile Include="@(PolyglotFile->'$(PolyglotOutDir)%(Filename).cs')" />
      <FileWrites Include="@(PolyglotFile->'$(PolyglotOutDir)%(Filename).cs')" />
    </ItemGroup>
  </Target>

</Project>
