// Issue #11 (1.B): a shared library module. Its type + free function are imported by entry.pg; under proper
// module linking each is DEFINED here (in nn.*) and REFERENCED from entry.* — never inlined/duplicated, so
// compiling entry + nn into one C# assembly does not hit CS0101.
class PgThing {
  var v: f64
  constructor(v: f64) { this.v = v }
}
fn twice(x: f64): f64 { return x * 2.0 }
