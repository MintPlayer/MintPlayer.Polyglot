// Scenario: a user-defined 2-D indexer with BOTH halves — a multi-arg read `g[x, y]` (#42) and a
// write `g[x, y] = v` (#40). On C# the two halves MERGE into one `this[int x, int y] { get; set; }`
// (the write used to emit invalid `static void operator set`); targets that emulate operators lower the
// read to `.get(x, y)` and the write to `.set(x, y, v)`. PHP refuses operator overloading (pinned
// refuser). Output must match across C#/TS/Python (C# is the oracle).

import { List } from "std.collections"

class Grid {
  var cells: List<i32>
  let w: i32

  init(w: i32, h: i32) {
    this.w = w
    this.cells = List<i32>()
    for i in 0..(w * h) { this.cells.add(i) }
  }

  operator fn get(x: i32, y: i32): i32 => this.cells[y * this.w + x]
  operator fn set(x: i32, y: i32, v: i32) { this.cells[y * this.w + x] = v }
}

fn main() {
  let g = Grid(3, 2)    // a 3x2 grid holding cells 0..5 row-major
  print(g[0, 0])        // 0
  print(g[2, 0])        // 2
  print(g[2, 1])        // 1*3 + 2 = 5
  g[2, 1] = 41          // write through the indexer setter
  print(g[2, 1] + 1)    // 42 — read-back inside an expression
}
