// Scenario: tuples in isolation — construction, tuple returns threaded through calls, tuples as list
// elements, for-loop destructuring, AND `let (a, b) = t` statement destructuring (#39b, was narrowed out).

import { List } from "std.collections"

fn swap(t: (i32, i32)): (i32, i32) {
  let (a, b) = t
  return (b, a)
}

fn main() {
  var pairs: List<(i32, string)> = [(1, "one"), (2, "two")]
  for (n, s) in pairs {
    print("${n}=${s}")   // 1=one / 2=two
  }
  let (p, q) = swap((3, 9))
  print(p)               // 9
  print(q)               // 3
}
