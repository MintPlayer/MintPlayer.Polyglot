// Scenario: typed catch with a `when` guard, a FALSE guard falling through to a SECOND same-type catch
// arm, an unmatched exception type propagating out to an enclosing try, and finally ordering.
// Previously narrowed: on Python/PHP a false guard re-raised and escaped the whole try (issue #44). Fixed
// by mirroring the TS `__handled` if-chain — a false guard now falls through to the next matching arm, and
// the trailing re-raise is gated on there being no catch-all. This program is that acceptance test.

class AppError : Error {
  let code: i32
  constructor(message: string, code: i32) {
    super(message)
    this.code = code
  }
}

class OtherError : Error {
  constructor(message: string) { super(message) }
}

fn boom(code: i32) {
  if code < 0 { throw OtherError("other") }
  throw AppError("app", code)
}

fn classify(code: i32): string {
  try {
    boom(code)
    return "none"
  } catch (e: AppError) when (e.code == 1) {
    return "guarded-one"
  } catch (e: AppError) {
    // The false-guard fall-through: a second AppError arm after the guarded one. On Python/PHP this used
    // to be unreachable because the guarded arm's re-raise escaped the whole try.
    return "app-other-${e.code}"
  } catch (e: OtherError) {
    return "other-kind"
  }
  // Unreachable at runtime (every arm returns), but the guard-emulation if-chain is not flow-provable, so
  // a trailing return is required for tsc.
  return "unreachable"
}

// The inner try catches only OtherError (guarded), but an AppError is thrown — with no catch-all the
// exception must re-raise and escape to the enclosing try in main.
fn escapes(): string {
  try {
    throw AppError("esc", 9)
    return "none"
  } catch (e: OtherError) when (e.message == "never") {
    return "inner-other"
  }
  return "inner-fell-through"
}

fn main() {
  print(classify(1))     // guarded-one   (guard true)
  print(classify(2))     // app-other-2   (guard false -> second AppError arm)
  print(classify(-1))    // other-kind    (different type)
  try {
    print(escapes())
  } catch (e: AppError) {
    print("outer: ${e.message}-${e.code}")   // outer: esc-9
  } finally {
    print("done")
  }
}
