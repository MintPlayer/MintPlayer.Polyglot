// Wave-2 G17 + #56b: GENERIC extension methods on List<T>, including a function-typed parameter whose
// lambda argument uses a std method on the generic-instantiated parameter (`s.len()` where T = string).
// The lambda param's type is now bidirectionally instantiated from the extension's `(T) => i32` param
// before the body is checked, so `s.len()` binds instead of emitting verbatim and crashing at runtime.

import { List } from "std.collections"
import "std.strings"

extension fn List<T>.second(): T? => if this.count > 1 { this[1] } else { null }

extension fn List<T>.totalWith(f: (T) => i32): i32 {
  var s = 0
  for x in this { s = s + f(x) }
  return s
}

fn main() {
  var xs: List<i32> = [3, 5, 8]
  print(xs.second() ?? -1)              // 5
  var ys: List<i32> = [4]
  print(ys.second() ?? -1)              // -1
  var ss: List<string> = ["x", "yy"]
  print(ss.second() ?? "none")          // yy   (string instantiation)
  print(xs.totalWith((v) => v * 2))     // 32
  print(xs.totalWith((v) => if v > 4 { 1 } else { 0 }))   // 2
  print(ss.totalWith((s) => s.len()))   // 1 + 2 = 3  (std method on a generic-instantiated lambda param)
}
