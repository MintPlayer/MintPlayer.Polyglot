// Scenario: char literals, string escapes (\n, \t, \"), codePoints() iteration, and string value
// equality — ASCII only (PHP's string std is byte-oriented, the documented caveat).

import "std.strings"

fn sameText(a: string, b: string): bool => a == b

fn main() {
  var c = 'A'
  print(c)                      // A
  print("tab:\there")           // tab:<TAB>here
  print("line1\nline2")         // two lines
  print("quote:\"q\"")          // quote:"q"
  var n = 0
  for cp in "abc".codePoints() { n += 1 }
  print(n)                      // 3
  // Equality routes through string-typed params: tsc 5.8 flags a direct
  // literal-vs-literal `===` as TS2367 in the emitted library-mode TS.
  print(sameText("abc", "abc")) // true
  print(sameText("abc", "abd")) // false
  print("x".charAt(0) == "x")   // true
}
