// P5 differential conformance: throw + typed catch + finally. `Error` is the
// core exception root (C# System.Exception / JS Error), so this is self-
// contained (no std). Observes try-body / catch / finally ordering on the
// normal and the thrown path.

fn run(x: i32) {
  try {
    if x < 0 {
      throw Error("negative")
    }
    print(1)            // try body ran to completion
  } catch (e: Error) {
    print(2)            // caught the throw
  } finally {
    print(3)            // always runs
  }
}

fn main() {
  run(5)      // 1, 3
  run(-1)     // 2, 3
}
