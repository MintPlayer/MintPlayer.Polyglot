// issue #36 regression guard: a List held in a class field keeps working after the PHP ArrayObject
// move — mutation through `this.*` inside methods was always correct (PHP objects are references)
// and must stay correct.

import { List } from "std.collections"

class Bag {
  var items: List<i32>

  init() {
    this.items = List<i32>()
  }

  fn put(v: i32) {
    this.items.add(v)
  }

  fn total(): i32 {
    var t = 0
    for x in this.items { t += x }
    return t
  }
}

fn main() {
  let bag = Bag()
  bag.put(10)
  bag.put(20)
  bag.put(30)
  print(bag.items.count)   // 3
  print(bag.total())       // 60
  bag.items.removeAt(1)
  print(bag.total())       // 40
}
