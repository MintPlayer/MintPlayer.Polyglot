// Scenario: break/continue in for and while, and break's scope in nested loops (inner only).
// Previously only incidental inside fruitcake.

fn main() {
  var sum = 0
  for i in 0..10 {
    if i % 2 == 0 { continue }
    if i > 7 { break }
    sum += i
  }
  print(sum)     // 1 + 3 + 5 + 7 = 16

  // NOTE: named `k`, not `i` — reusing a for-binding's name for a later method-scope local emits
  // C# that trips CS0136 (the for's `var i` and the later `var i` share one method scope on C#).
  // Valid .pg -> invalid C#; issue #41. Sidestepped here so the loop semantics stay pinned.
  var hits = 0
  var k = 0
  while true {
    k += 1
    if k % 3 != 0 { continue }
    hits += 1
    if hits == 2 { break }
  }
  print(k)       // 6

  for a in 0..3 {
    for b in 0..3 {
      if b > a { break }      // breaks the INNER loop only
      print(a * 10 + b)       // 0, 10, 11, 20, 21, 22
    }
  }
}
