// P6 differential conformance: explicit numeric casts `(T)value`. Covers the
// BigInt boundary (i32<->i64), float<->int truncation, and narrowing — each
// lowered to the target idiom (C# native casts; TS BigInt()/Number()/trunc).

fn main() {
  let x = 7
  let wide = (i64)x            // i32 -> i64 (BigInt)
  print(wide * wide)           // 49

  let big = 1000000007i64
  print((i32)(big % 1000i64))  // 7   (i64 -> i32)

  let f = (f64)x               // i32 -> f64
  print((i32)(f / 2.0))        // 3   (f64 3.5 -> i32, truncates)

  print((i32)(-7.9))           // -7  (truncates toward zero)
  print((i64)(f * f))          // 49  (f64 49.0 -> i64)
}
