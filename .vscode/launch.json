{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Polyglot VS Code extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "build-cli",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/editors/vscode",
        "${workspaceFolder}/editors/vscode/testbench"
      ]
    }
  ]
}
